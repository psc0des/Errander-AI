# Errander Agent Process Environment Variables
# Copy to /home/errander-agent/.env.agent and fill in actual values
# Do NOT commit the filled-in file to git — add to .gitignore

# === LLM Configuration (required) ===
# Path A: cloud API (e.g., OpenAI, Anthropic via OpenAI-compat endpoint)
ERRANDER_LLM_BASE_URL=https://api.openai.com/v1
ERRANDER_LLM_MODEL=gpt-4o-mini
ERRANDER_LLM_API_KEY=sk-...

# Path B: self-hosted vLLM
# ERRANDER_LLM_BASE_URL=http://10.0.0.10:8000/v1
# ERRANDER_LLM_MODEL=Qwen/Qwen3-8B-AWQ
# ERRANDER_LLM_API_KEY=not-needed

ERRANDER_LLM_TEMPERATURE=0.1
ERRANDER_LLM_TIMEOUT=60

# === Slack Integration (required) ===
ERRANDER_SLACK_BOT_TOKEN=xoxb-...
ERRANDER_SLACK_CHANNEL_ID=C0123456789

# === SSH Execution (required) ===
# Path to SSH key file. Must be readable by errander-agent user (mode 0600).
# Never store inline key material here.
ERRANDER_SSH_KEY_PATH=/home/errander-agent/.ssh/id_rsa

# === Audit Database (required) ===
# PostgreSQL URL for shared audit trail (accessible to both agent and web processes)
ERRANDER_AUDIT_DB_URL=postgresql://errander:errander@db.internal:5432/errander

# === Optional: Agent Scheduling ===
# Defaults: first run 01:00 UTC daily, no maintenance windows (runs any time)
# ERRANDER_SCHEDULE_CRON=0 1 * * *
# ERRANDER_SCHEDULE_WINDOWS=

# === Optional: LLM Provider Tweaks ===
# Only set if using non-standard endpoint or provider-specific configs
# ERRANDER_LLM_REQUEST_TIMEOUT=30
# ERRANDER_LLM_MAX_RETRIES=3
