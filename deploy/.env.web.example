# Errander Web UI Process Environment Variables
# Copy to /home/errander-web/.env.web and fill in actual values
# Do NOT commit the filled-in file to git — add to .gitignore

# === Audit Database (required) ===
# Same PostgreSQL instance as agent process (shared audit trail)
ERRANDER_AUDIT_DB_URL=postgresql://errander:errander@db.internal:5432/errander

# === Signing Secret (required for docker_hygiene approval links) ===
# 32+ random bytes, base64-encoded. Generate with:
#   head -c 32 /dev/urandom | base64
ERRANDER_SIGNING_SECRET=ABC...xyz==

# === Web Server Configuration ===
# Port: which port the web UI listens on (default 9091)
ERRANDER_WEB_PORT=9091

# Base URL: externally-reachable URL for this web instance
# Used to build signed approval links in Slack messages (docker_hygiene action)
# Examples:
#   - http://10.0.0.5:9091 (private network)
#   - https://errander.example.com (via nginx reverse proxy, TLS)
# Leave empty to disable signed-URL generation (approvals still work, just no link)
ERRANDER_WEB_BASE_URL=http://10.0.0.5:9091

# === Optional: Public Mode (nginx reverse proxy, TLS, mandatory TOTP) ===
# Set to true when running behind nginx Mode 2 with TLS + IP allowlist
# Mandates TOTP (two-factor auth) for admin group
# ERRANDER_PUBLIC_MODE=false
