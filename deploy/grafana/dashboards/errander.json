{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [

    {
      "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
        "expr": "sum(increase(errander_actions_total[$__range]))",
        "instant": true,
        "legendFormat": "Actions"
      }],
      "title": "Actions",
      "description": "Total maintenance actions executed in the selected time range",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green",  "value": 95 }
            ]
          },
          "unit": "percent",
          "min": 0, "max": 100,
          "noValue": "—"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
        "expr": "sum(increase(errander_actions_total{status=\"success\"}[$__range])) / (sum(increase(errander_actions_total[$__range])) > 0) * 100",
        "instant": true,
        "legendFormat": "Success Rate"
      }],
      "title": "Action Success Rate",
      "description": "Percentage of actions that completed successfully",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green",  "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0, "max": 100,
          "noValue": "—"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
        "expr": "sum(rate(errander_llm_requests_total{outcome=\"success\"}[$__rate_interval])) / (sum(rate(errander_llm_requests_total[$__rate_interval])) > 0) * 100",
        "instant": true,
        "legendFormat": "LLM Health"
      }],
      "title": "LLM Health",
      "description": "Percentage of LLM calls that succeeded (vs fallback/timeout/error)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 25 }
            ]
          },
          "unit": "percent",
          "min": 0, "max": 100,
          "noValue": "0%"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
        "expr": "sum(rate(errander_llm_requests_total{outcome=\"fallback\"}[$__rate_interval])) / (sum(rate(errander_llm_requests_total[$__rate_interval])) > 0) * 100",
        "instant": true,
        "legendFormat": "Fallback Rate"
      }],
      "title": "LLM Fallback Rate",
      "description": "How often the agent falls back to hardcoded logic due to LLM unavailability",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
        "expr": "sum by (action_type) (increase(errander_actions_total[1h]))",
        "legendFormat": "{{ action_type }}"
      }],
      "title": "Actions per Hour by Type",
      "description": "Maintenance actions executed per hour, broken out by action type",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "failed"  }, "properties": [{ "id": "color", "value": { "fixedColor": "red",   "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "skipped" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue",  "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
        "expr": "sum by (status) (increase(errander_actions_total[1h]))",
        "legendFormat": "{{ status }}"
      }],
      "title": "Action Outcomes per Hour",
      "description": "Action results (success / failed / skipped / dry_run) per hour",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 7,
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(errander_batch_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(errander_batch_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "title": "Batch Duration (p50 / p95)",
      "description": "Time to complete a full maintenance batch across all VMs in an environment",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "fallback"}, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "timeout" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "error"   }, "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 8,
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
        "expr": "sum by (outcome) (rate(errander_llm_requests_total[$__rate_interval]))",
        "legendFormat": "{{ outcome }}"
      }],
      "title": "LLM Requests by Outcome",
      "description": "Rate of LLM calls: success = used AI; fallback = fell back to hardcoded logic",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 9,
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
        "expr": "sum by (reason) (rate(errander_ssh_errors_total[$__rate_interval]))",
        "legendFormat": "{{ reason }}"
      }],
      "title": "SSH Errors by Reason",
      "description": "Rate of SSH connection or command failures, broken out by failure reason",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 10,
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(errander_approval_wait_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "errander-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(errander_approval_wait_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "title": "Approval Wait (p50 / p95)",
      "description": "Time operators take to approve or reject maintenance plans in Slack / Web UI",
      "type": "timeseries"
    }

  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["errander", "sre", "ops"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Errander-AI Fleet Operations",
  "uid": "errander-ai-ops",
  "version": 1
}
