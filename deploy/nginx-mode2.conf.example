# Errander Web UI — nginx Mode 2 (public internet, TLS hardened)
#
# This is a reference configuration for deploying the web UI behind nginx
# with TLS, HSTS, rate limiting, and optional IP allowlist.
#
# === Prerequisites ===
# 1. errander-web process listening on 127.0.0.1:9091 (loopback, not exposed)
# 2. TLS certificate (self-signed, Let's Encrypt, or corporate CA)
# 3. Admin users have TOTP enabled (mandatory in public mode)
# 4. ERRANDER_PUBLIC_MODE=true set in /home/errander-web/.env.web
#
# === Installation ===
# 1. Copy this file to /etc/nginx/sites-available/errander-web
# 2. Edit upstream server, server_name, ssl_certificate paths, and rate limits
# 3. Enable site: ln -s /etc/nginx/sites-available/errander-web /etc/nginx/sites-enabled/
# 4. Test config: nginx -t
# 5. Reload: systemctl reload nginx

upstream errander_web {
    # Must match ERRANDER_WEB_PORT in /home/errander-web/.env.web
    server 127.0.0.1:9091;
    keepalive 32;
}

# Rate limiting buckets
limit_req_zone $binary_remote_addr zone=login_limit:10m rate=5r/m;
limit_req_zone $binary_remote_addr zone=api_limit:10m rate=100r/m;

server {
    listen 80;
    listen [::]:80;
    server_name errander.example.com;
    # Redirect HTTP to HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name errander.example.com;

    # === TLS Configuration ===
    ssl_certificate /etc/letsencrypt/live/errander.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/errander.example.com/privkey.pem;

    # TLS security hardening
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # === Security Headers ===
    # HSTS: strict transport security (6 months)
    add_header Strict-Transport-Security "max-age=15552000; includeSubDomains; preload" always;
    # Prevent clickjacking
    add_header X-Frame-Options "DENY" always;
    # Disable content type sniffing
    add_header X-Content-Type-Options "nosniff" always;
    # XSS protection
    add_header X-XSS-Protection "1; mode=block" always;

    # === Optional: IP Allowlist ===
    # Restrict access to known operator IP ranges (VPN, office, etc.)
    # Uncomment and adjust to your network topology
    # geo $ip_whitelist {
    #     default 0;
    #     10.0.0.0/8 1;       # Internal VPN
    #     203.0.113.0/24 1;   # Office IP range
    # }
    # if ($ip_whitelist = 0) {
    #     return 403;
    # }

    # === Logging ===
    access_log /var/log/nginx/errander-access.log combined;
    error_log /var/log/nginx/errander-error.log warn;

    # === Upstream Proxy ===
    location / {
        # Rate limiting: API requests (100 req/min per IP)
        limit_req zone=api_limit burst=20 nodelay;

        proxy_pass http://errander_web;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
        proxy_send_timeout 30s;
    }

    # === Login Endpoint: Extra Rate Limiting ===
    location /ui/login {
        # Aggressive rate limiting on login: 5 req/min per IP
        limit_req zone=login_limit burst=5 nodelay;

        proxy_pass http://errander_web;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
