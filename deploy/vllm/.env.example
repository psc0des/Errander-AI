# vLLM deployment configuration
# Copy to .env and fill in values before running docker compose up -d

# ---------------------------------------------------------------------------
# Model
# ---------------------------------------------------------------------------

# HuggingFace model ID to serve.
# Qwen3-8B-AWQ is ~5GB download, fits in 16GB VRAM with room to spare.
MODEL_ID=Qwen/Qwen3-8B-AWQ

# Name the agent uses when calling the API (must match ERRANDER_LLM_MODEL
# in the agent's settings.yaml if set, otherwise any name works).
SERVED_MODEL_NAME=qwen3-8b

# HuggingFace token — only needed if the model repo is private or gated.
# Qwen3-8B-AWQ is public, so leave blank unless you have a private mirror.
HF_TOKEN=

# ---------------------------------------------------------------------------
# Hardware tuning (Tesla T4, 16GB VRAM)
# ---------------------------------------------------------------------------

# Maximum sequence length. 8192 fits comfortably in 16GB VRAM.
# Reducing this frees VRAM but limits context window.
MAX_MODEL_LEN=8192

# Fraction of GPU VRAM reserved for the model + KV cache.
# 0.85 leaves ~2.4GB headroom for activation spikes.
# Reduce to 0.80 if you see CUDA OOM errors.
GPU_MEM_UTIL=0.85

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------

# Port to expose on the host. The agent connects to http://<this-vm-ip>:<port>
# Set ERRANDER_LLM_BASE_URL=http://<this-vm-ip>:<VLLM_PORT>/v1 in the agent config.
VLLM_PORT=8000

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

# Directory on the host where HuggingFace model weights are cached.
# First run downloads ~5GB here. Subsequent starts load from cache (~30s).
# Make sure this path has enough disk space and survives reboots.
MODEL_CACHE_DIR=/opt/vllm/model-cache
